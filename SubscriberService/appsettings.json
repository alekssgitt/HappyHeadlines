{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "SubscriberDb": "Host=subscriber-db;Port=5432;Database=subscribers;Username=postgres;Password=postgres"
  },
  "Queue": {
    "Host": "rabbitmq",
    "Port": 5672,
    "UserName": "guest",
    "Password": "guest",
    "SubscriberQueueName": "subscriber-queue"
  },
  "ReleaseToggles": {
